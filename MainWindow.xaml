<Window x:Class="CS_Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CS_Launcher"
        mc:Ignorable="d"
        Title="CS Launcher" Height="275" Width="400" ResizeMode="CanMinimize" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0" Content="System:" VerticalAlignment="Center"/>
        <TextBox x:Name="TxtSystem" Grid.Row="0" Grid.Column="1" Margin="0,4" VerticalContentAlignment="Center" KeyDown="TxtField_KeyDown"/>

        <Label Grid.Row="1" Grid.Column="0" Content="Login:" VerticalAlignment="Center"/>
        <TextBox x:Name="TxtLogin" Grid.Row="1" Grid.Column="1" Margin="0,4" VerticalContentAlignment="Center" KeyDown="TxtField_KeyDown"/>

        <Label Grid.Row="2" Grid.Column="0" Content="Password:" VerticalAlignment="Center"/>
        <PasswordBox x:Name="TxtPassword" Grid.Row="2" Grid.Column="1" Margin="0,4" KeyDown="TxtPassword_KeyDown"/>

        <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,12,0,0" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Exit" Width="80" Margin="0,0,8,0" Click="BtnLogOff_Click"/>
            <Button Content="LogOn" Width="80" Click="BtnStart_Click"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Vertical" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <CheckBox x:Name="ChkAttachToProcess"
                          Content="Restart ViewX after"
                          Unchecked="ChkAttachToProcess_Unchecked"
                          VerticalAlignment="Center"/>
                <TextBox x:Name="TxtRestartDelaySeconds"
                         Width="48"
                         Margin="8,0,0,0"
                         VerticalContentAlignment="Center"
                         Text="10"/>
                <TextBlock Text="sec" Margin="6,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,8,0,0" VerticalAlignment="Center">
                <CheckBox x:Name="ChkExitAfter"
                          Content="Exit after"
                          Unchecked="ChkExitAfter_Unchecked"
                          VerticalAlignment="Center"/>
                <TextBox x:Name="TxtExitDelayMinutes"
                         Width="48"
                         Margin="8,0,0,0"
                         VerticalContentAlignment="Center"
                         Text="120"/>
                <TextBlock Text="minutes of inactivity" Margin="6,0,0,0" VerticalAlignment="Center" Width="232"/>
            </StackPanel>
        </StackPanel>

        <Viewbox Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                 Margin="0,8,0,0" Stretch="Uniform" StretchDirection="DownOnly" Height="47">
            <TextBlock x:Name="TxtError"
                       Foreground="Red"
                       TextWrapping="NoWrap"
                       VerticalAlignment="Top"/>
        </Viewbox>
    </Grid>
</Window>
